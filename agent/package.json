{
  "name": "@cadence/agent",
  "version": "0.1.0",
  "description": "Cadence agent service: planner (LLM) + deterministic executor.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./executor/guardrails": {
      "types": "./dist/executor/guardrails.d.ts",
      "default": "./dist/executor/guardrails.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cadence/mandate": "0.1.0",
    "@casper-ecosystem/casper-eip-712": "1.2.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@noble/curves": "2.2.0",
    "casper-js-sdk": "5.0.12",
    "dotenv": "17.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
